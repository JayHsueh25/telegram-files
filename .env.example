# ==============================
# 基础运行配置
# ==============================

# 应用日志级别，可选：ALL、FINEST、FINER、FINE、CONFIG、INFO、WARNING、SEVERE、OFF
LOG_LEVEL=INFO

# 应用运行环境。Docker 部署保持 prod 即可
APP_ENV=prod

# 应用数据目录。数据库、日志、Telegram 账号数据都会默认放在这里
APP_ROOT=/app/data

# ==============================
# 数据库配置
# ==============================

# 默认使用 SQLite，无需填写下面的数据库配置。
# 如需使用外部数据库，把 DB_TYPE 改为 postgres 或 mysql，并打开对应连接配置。
#DB_TYPE=postgres
#DB_HOST=localhost
#DB_PORT=5432
#DB_USER=postgres
#DB_PASSWORD=postgres
#DB_NAME=telegram-files

# 需要程序自动创建数据库时设置为 true。一般只在外部数据库初始化场景使用
#DB_NEED_CREATE=false

# ==============================
# Docker 容器配置
# ==============================

# 指定容器内运行服务的用户 ID 和用户组 ID，常用于避免挂载目录权限问题
#PUID=1000
#PGID=1000

# Nginx 在容器内监听的端口。通常保持 80，宿主机端口在 docker-compose.yaml 的 ports 中映射
#NGINX_PORT=80

# 如果你的 fork 发布到了自己的 Docker Hub 命名空间，可以改成你的镜像名
# 例如：jayhsueh25/telegram-files:latest
#DOCKERHUB_IMAGE=jarvis2f/telegram-files:latest

# ==============================
# Telegram 配置
# ==============================

# Telegram API ID 和 API HASH，必须从 https://my.telegram.org/apps 申请
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# TDLib 日志级别。0 表示只记录致命错误，数字越大日志越详细
TELEGRAM_LOG_LEVEL=0

# ==============================
# 管理员账号配置
# ==============================

# 初始管理员账号密码只在首次初始化、数据库尚未保存管理员凭据时生效
# 生产环境请在第一次启动前改掉默认值，并在登录后通过右上角“账号安全”再次修改
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# ==============================
# OpenAI 配置
# ==============================

# 可选。需要使用 AI 相关能力时填写
#OPENAI_API_KEY=

# OpenAI 模型名称，默认 gpt-4o-mini
#OPENAI_MODEL=

# OpenAI API 地址，默认 https://api.openai.com/v1
#OPENAI_BASE_URL=

# ==============================
# 详细解释
# ==============================

# LOG_LEVEL：控制 Java 服务输出日志的详细程度。排查问题时可临时改为 FINE 或 FINER，正常使用建议 INFO。
# APP_ENV：运行环境标识。prod 会按生产模式运行，普通 Docker 部署不要改。
# APP_ROOT：容器内的数据根目录。docker-compose.yaml 默认把宿主机 ./data 挂载到 /app/data，因此重建容器也不会丢数据。
# DB_TYPE：数据库类型。未设置时使用 SQLite；设置为 postgres 或 mysql 时，需要同时配置 DB_HOST、DB_PORT、DB_USER、DB_PASSWORD、DB_NAME。
# DB_NEED_CREATE：是否尝试自动创建外部数据库。已有数据库或使用 SQLite 时一般保持 false。
# PUID / PGID：让容器内进程按指定用户运行，适合 NAS、unRaid、Linux 服务器挂载目录权限不一致的场景。
# NGINX_PORT：容器内部 Nginx 监听端口。大多数部署保持 80，只改 docker-compose.yaml 的宿主机端口映射即可。
# DOCKERHUB_IMAGE：docker-compose.yaml 使用的镜像名。官方默认 jarvis2f/telegram-files:latest；自己 fork 发布时改成自己的 Docker Hub 镜像。
# TELEGRAM_API_ID / TELEGRAM_API_HASH：Telegram 官方 API 凭据，是启动服务的必填项。
# TELEGRAM_LOG_LEVEL：TDLib 原生日志级别。0 最安静，排查 Telegram 登录或下载问题时可适当调高。
# ADMIN_USERNAME / ADMIN_PASSWORD：初始后台登录账号密码。它们只在首次初始化生效，后续请在网页右上角“账号安全”中修改账号和密码。
# OPENAI_API_KEY / OPENAI_MODEL / OPENAI_BASE_URL：AI 功能配置。不使用 AI 能力时可以全部留空。
